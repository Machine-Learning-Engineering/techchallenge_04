# ============================================================================
# CONFIGURAÇÕES DE LOGGING
# ============================================================================

# Nível de logging: DEBUG, INFO, WARNING, ERROR, CRITICAL
# Use DEBUG para investigar problemas de carga de dados
# Use INFO para produção
LOG_LEVEL=DEBUG

# Diretório para armazenar os arquivos de log
LOG_DIR=logs

# Habilitação de logging em arquivo
# true = escrever logs em arquivo, false = apenas console
ENABLE_FILE_LOGGING=true

# Habilitação de logging em console
# true = exibir logs no console, false = apenas arquivo
ENABLE_CONSOLE_LOGGING=true

# ============================================================================
# CONFIGURAÇÕES DA APLICAÇÃO
# ============================================================================

# Porta da API
API_PORT=5001

# Porta do Dashboard
DASHBOARD_PORT=5000

# Porta da Interface Web
WEB_INTERFACE_PORT=8080

# Modelo LSTM a utilizar
MODEL_PATH=lstm_model_AAPL.keras

# Arquivo de dados históricos
DATA_PATH=data/NASDAQ100_Historical_Data.csv

# Diretório para logs de monitoramento
MONITORING_DIR=monitoring_logs

# ============================================================================
# COMO USAR
# ============================================================================

# 1) Copie este arquivo como .env:
#    cp .env.example .env
#
# 2) Edite o arquivo .env com seus valores desejados
#
# 3) Para carregar as variáveis de ambiente (Linux/Mac):
#    export $(cat .env | grep -v '^#' | xargs)
#
# 4) Para carregar em Python, use python-dotenv:
#    pip install python-dotenv
#    from dotenv import load_dotenv
#    load_dotenv(".env")
#
# 5) Exemplos de uso:
#
#    # DEBUG completo (mais verbose, encontra erros de carregamento de dados):
#    LOG_LEVEL=DEBUG ENABLE_FILE_LOGGING=true python api.py
#
#    # INFO (produção):
#    LOG_LEVEL=INFO ENABLE_FILE_LOGGING=true python api.py
#
#    # Apenas console, sem arquivos:
#    LOG_LEVEL=DEBUG ENABLE_FILE_LOGGING=false python api.py
#
# 6) Os arquivos de log serão salvos em LOG_DIR com timestamp:
#    logs/app_20260303_153045.log

# ============================================================================
# DESCRIÇÃO DOS NÍVEIS
# ============================================================================

# DEBUG - Informações detalhadas para diagnosticar problemas
#   - Caminhos de arquivo completos
#   - Tamanho dos arquivos carregados
#   - Estrutura de DataFrames
#   - Valores de normalização
#   - Camadas do modelo
#   - Arrays de entrada/saída

# INFO - Confirmações de operações bem-sucedidas
#   - Aplicação inicializada
#   - Modelo carregado
#   - Dados carregados com quantidade de registros

# WARNING - Situações não ideais mas que funcionam
#   - Arquivo não encontrado em local secundário
#   - Taxa de erro baixa em requisições

# ERROR - Erros que afetam a funcionalidade
#   - Arquivo não encontrado
#   - Ticker inválido
#   - Erro na predição

# CRITICAL - Erros que podem derrubar a aplicação
#   - Falha ao carregar modelo
#   - Falha ao inicializar

# ============================================================================
# SUGESTÕES PARA DEPURAÇÃO
# ============================================================================

# Para encontrar erros de carga de dados:
#   1. Use LOG_LEVEL=DEBUG
#   2. Verifique os caminos de arquivo com:
#      grep "Caminho absoluto\|encontrado\|CSV" logs/app_*.log | head -20
#   3. Procure por mensagens de erro:
#      grep "❌\|erro\|ERROR" logs/app_*.log

# Para monitorar normalização de dados:
#   LOG_LEVEL=DEBUG python api.py 2>&1 | grep -i "scaler\|normaliz\|min\|max"

# Para entender fluxo de carregamento:
#   LOG_LEVEL=DEBUG python api.py 2>&1 | grep -E "Carregando|DEBUG"
